# Domain publik untuk akses Airflow
PUBLIC_DOMAIN=airflow.example.com
AIRFLOW_PUBLIC_BASE_URL=https://airflow.example.com
METABASE_PUBLIC_DOMAIN=metabase.example.com
METABASE_PUBLIC_BASE_URL=https://metabase.example.com
METABASE_DB_HOST=postgres
METABASE_DB_PORT=5432
METABASE_DB_NAME=metabase
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=CHANGE_ME_METABASE_DB_PASSWORD

# Admin Airflow (WAJIB diganti)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Kunci Airflow (generate sendiri)
# Contoh generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_FERNET_KEY
AIRFLOW__WEBSERVER__SECRET_KEY=CHANGE_ME_WEBSERVER_SECRET
METABASE_ENCRYPTION_SECRET_KEY=CHANGE_ME_METABASE_SECRET

# API
API1_URL=https://dtrace.id/api/senesa/wallet/logistic-orders
API1_LIMIT=100
API2_URL=https://dtrace.id/api/spx/orders
API2_LIMIT=100
API2_SOURCE_MODE=spx_web

# SPX Web scraping mode (pakai jika API2 diganti scraper web)
SPX_WEB_LOGIN_URL=https://spx.co.id/
SPX_WEB_TRACKING_URL=https://spx.co.id/spx-admin/order/trackings
SPX_WEB_USERNAME=
SPX_WEB_PASSWORD=
SPX_WEB_HEADLESS=true
SPX_WEB_DOWNLOAD_DIR=/opt/airflow/data/spx_downloads
SPX_WEB_POST_LOGIN_WAIT_FOR=networkidle
SPX_WEB_USERNAME_SELECTOR=input[type='text']
SPX_WEB_PASSWORD_SELECTOR=input[type='password']
SPX_WEB_SUBMIT_SELECTOR=button[type='submit']
SPX_WEB_DOWNLOAD_SELECTOR=button:has-text('Unduh')
SPX_WEB_TRACKING_TABLE_SELECTOR=table
# Opsional jika ingin isi filter tanggal otomatis
SPX_WEB_START_DATE_SELECTOR=
SPX_WEB_END_DATE_SELECTOR=
SPX_WEB_APPLY_FILTER_SELECTOR=

# DB
DB_HOST=postgres
DB_PORT=5432
DB_NAME=returns_db
DB_USER=admin
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
